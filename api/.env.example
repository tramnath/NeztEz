PORT=8080
NODE_ENV=development
ADMIN_API_KEY=

# Zoho OAuth / Sign
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REDIRECT_URI=
ZOHO_ACCOUNTS_BASE_URL=https://accounts.zoho.com
ZOHO_SIGN_API_BASE_URL=https://sign.zoho.com/api/v1
ZOHO_SCOPES=ZohoSign.documents.ALL

# Optional static token (for quick testing only)
ZOHO_ACCESS_TOKEN=
ZOHO_KV_ACCESS_TOKEN_SECRET_NAME=zoho-sign-access-token
ZOHO_KV_REFRESH_TOKEN_SECRET_NAME=zoho-sign-refresh-token
ZOHO_KV_ACCESS_TOKEN_EXPIRY_SECRET_NAME=zoho-sign-access-token-expiry

# Webhook verification
ZOHO_WEBHOOK_SECRET=
ZOHO_WEBHOOK_SIGNATURE_HEADER=x-zs-signature

# Azure resources
AZURE_KEY_VAULT_URL=
AZURE_STORAGE_ACCOUNT_URL=
APPINSIGHTS_CONNECTION_STRING=
